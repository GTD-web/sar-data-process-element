{
  "name": "sar-data-process-element",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/pipeline-workflow-subsystem/main",
    "lint": "eslint \"apps/**/*.ts\" \"libs/**/*.ts\" --max-warnings 0",
    "lint:py": "python -m ruff check algorithms && python -m ruff format algorithms --check && python -m mypy algorithms/csc03_range_compression",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/pipeline-workflow-subsystem/test/jest-e2e.json",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d libs/sdpe-database/src/data-source.ts",
    "migration:show": "typeorm-ts-node-commonjs migration:show -d libs/sdpe-database/src/data-source.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/supertest": "^6.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3",
    "typescript-eslint": "^8.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@sdpe/shared$": "<rootDir>/libs/sdpe-shared/src/index.ts",
      "^@sdpe/shared/(.*)$": "<rootDir>/libs/sdpe-shared/src/$1",
      "^@sdpe/database$": "<rootDir>/libs/sdpe-database/src/index.ts",
      "^@sdpe/database/(.*)$": "<rootDir>/libs/sdpe-database/src/$1",
      "^@sdpe/job$": "<rootDir>/libs/csu-07.01-job/src/index.ts",
      "^@sdpe/job/(.*)$": "<rootDir>/libs/csu-07.01-job/src/$1",
      "^@sdpe/pipeline$": "<rootDir>/libs/csu-07.02-pipeline/src/index.ts",
      "^@sdpe/pipeline/(.*)$": "<rootDir>/libs/csu-07.02-pipeline/src/$1",
      "^@sdpe/processing-profile$": "<rootDir>/libs/csu-07.03-processing-profile/src/index.ts",
      "^@sdpe/processing-profile/(.*)$": "<rootDir>/libs/csu-07.03-processing-profile/src/$1",
      "^@sdpe/retry-policy$": "<rootDir>/libs/csu-07.04-retry-policy/src/index.ts",
      "^@sdpe/retry-policy/(.*)$": "<rootDir>/libs/csu-07.04-retry-policy/src/$1",
      "^@sdpe/alert$": "<rootDir>/libs/csu-07.05-alert/src/index.ts",
      "^@sdpe/alert/(.*)$": "<rootDir>/libs/csu-07.05-alert/src/$1",
      "^@sdpe/audit-log$": "<rootDir>/libs/csu-07.06-audit-log/src/index.ts",
      "^@sdpe/audit-log/(.*)$": "<rootDir>/libs/csu-07.06-audit-log/src/$1",
      "^@sdpe/monitoring$": "<rootDir>/libs/csu-07.07-monitoring/src/index.ts",
      "^@sdpe/monitoring/(.*)$": "<rootDir>/libs/csu-07.07-monitoring/src/$1"
    },
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ]
  }
}
