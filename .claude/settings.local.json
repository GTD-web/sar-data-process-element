{
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(gh pr:*)",
      "Bash(winget install:*)",
      "Bash(gh auth:*)",
      "Bash(export PATH=\"$PATH:/c/Program Files/GitHub CLI\")",
      "Bash(mkdir -p /c/Users/USER/dev/sar-data-process-element/csci)",
      "Bash(mv /c/Users/USER/dev/sar-data-process-element/RawDataCollector /c/Users/USER/dev/sar-data-process-element/csci/csc-02-raw-data-collector)",
      "Bash(git push:*)",
      "Bash(find /c/Users/USER/dev/sar-data-process-element -type d -name *pipeline*)",
      "Bash(xargs grep:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "Add-Type -AssemblyName System.Windows.Forms; $n = New-Object System.Windows.Forms.NotifyIcon; $n.Icon = [System.Drawing.SystemIcons]::Information; $n.BalloonTipTitle = 'Claude Code'; $n.BalloonTipText = '작업이 완료되었습니다.'; $n.Visible = $true; $n.ShowBalloonTip(5000); Start-Sleep -Seconds 6; $n.Dispose()",
            "shell": "powershell"
          }
        ]
      }
    ]
  }
}
