{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/pipeline-workflow-subsystem/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/pipeline-workflow-subsystem/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/pipeline-workflow-subsystem",
  "projects": {
    "sdpe-shared": {
      "type": "library",
      "root": "libs/sdpe-shared",
      "entryFile": "index",
      "sourceRoot": "libs/sdpe-shared/src",
      "compilerOptions": {
        "tsConfigPath": "libs/sdpe-shared/tsconfig.lib.json"
      }
    },
    "sdpe-database": {
      "type": "library",
      "root": "libs/sdpe-database",
      "entryFile": "index",
      "sourceRoot": "libs/sdpe-database/src",
      "compilerOptions": {
        "tsConfigPath": "libs/sdpe-database/tsconfig.lib.json"
      }
    },
"data-collecting-subsystem": {
      "type": "application",
      "root": "apps/data-collecting-subsystem",
      "entryFile": "main",
      "sourceRoot": "apps/data-collecting-subsystem/src",
      "compilerOptions": {
        "tsConfigPath": "apps/data-collecting-subsystem/tsconfig.app.json"
      }
    },
    "sar-processing-subsystem": {
      "type": "application",
      "root": "apps/sar-processing-subsystem",
      "entryFile": "main",
      "sourceRoot": "apps/sar-processing-subsystem/src",
      "compilerOptions": {
        "tsConfigPath": "apps/sar-processing-subsystem/tsconfig.app.json"
      }
    },
    "post-processing-tool": {
      "type": "application",
      "root": "apps/post-processing-tool",
      "entryFile": "main",
      "sourceRoot": "apps/post-processing-tool/src",
      "compilerOptions": {
        "tsConfigPath": "apps/post-processing-tool/tsconfig.app.json"
      }
    },
    "pipeline-workflow-subsystem": {
      "type": "application",
      "root": "apps/pipeline-workflow-subsystem",
      "entryFile": "main",
      "sourceRoot": "apps/pipeline-workflow-subsystem/src",
      "compilerOptions": {
        "tsConfigPath": "apps/pipeline-workflow-subsystem/tsconfig.app.json"
      }
    },
"data-service-subsystem": {
      "type": "application",
      "root": "apps/data-service-subsystem",
      "entryFile": "main",
      "sourceRoot": "apps/data-service-subsystem/src",
      "compilerOptions": {
        "tsConfigPath": "apps/data-service-subsystem/tsconfig.app.json"
      }
    }
  }
}